rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: productos
    // Document ID: productId
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - description: string (optional, 0-1000 chars)
    //   - price: number (required, > 0)
    //   - images: list (required, max 5 URLs)
    //   - stock: number (required, >= 0)
    //   - category: string (required, 'ropa' or 'accesorios')
    //   - subcategory: string (required, 1-50 chars)
    //   - createdAt: timestamp (required)
    //
    // Collection: pedidos
    // Document ID: orderId
    // Fields:
    //   - items: list (required)
    //   - total: number (required, > 0)
    //   - customerName: string (optional)
    //   - paymentMethod: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: admin_users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, 'admin')
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "ramirezestebanramirez@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'images', 'stock', 'subcategory', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.price is number && data.price > 0 &&
             data.category in ['ropa', 'accesorios'] &&
             data.images is list && data.images.size() <= 5 &&
             data.stock is number && data.stock >= 0 &&
             data.subcategory is string && data.subcategory.size() > 0 && data.subcategory.size() <= 50;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'total', 'createdAt']) &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total > 0;
    }

    // Rules
    match /productos/{productId} {
      allow read: if true; // Publicly readable
      allow create, update, delete: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /pedidos/{orderId} {
      allow read: if isAdmin();
      allow create: if true; // Anyone can place an order (it's mostly for record since it goes to WhatsApp)
      allow update, delete: if isAdmin();
    }

    match /admin_users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
